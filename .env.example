# Ejemplo de variables de entorno para Docker Compose
# Copia este archivo a .env y ajusta los valores según tu entorno

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backend_development

# URL a la que apuntará el frontend compilado para hacer llamadas API
# En producción cambia esto a tu dominio real
VITE_API_URL=http://localhost:3000/api/v1
